{
  "name": "Neon Void",
  "description": "Red & Dark Blue Theme",
  "author": "Blurski",
  "background": {
    "url": "https://i.imgur.com/8jLAnkH.jpg",
    "blur": 0,
    "alpha": 0.1
  },
  "theme": {
    "colors": {
      "primary": "#8B0000",
      "background": "#0a0a1a",
      "surface": "#1a1a3a",
      "surfaceLow": "#111128",
      "surfaceHigh": "#2a1a2a",
      "accent": "#ff3333",
      "accentSecondary": "#2244aa",
      "text": "#f0f0ff",
      "textSecondary": "#aab0cc",
      "textMuted": "#666688",
      "success": "#44ff88",
      "warning": "#ffaa00",
      "danger": "#ff2244",
      "border": "#442233"
    },
    "radii": {
      "small": 6,
      "medium": 12,
      "large": 20
    },
    "shadows": {
      "small": "0 2px 8px rgba(200, 0, 0, 0.2)",
      "medium": "0 4px 20px rgba(30, 60, 180, 0.3)",
      "large": "0 8px 40px rgba(200, 0, 0, 0.15)"
    },
    "fonts": {
      "body": "Inter, system-ui, sans-serif",
      "monospace": "JetBrains Mono, monospace"
    }
  }
}
