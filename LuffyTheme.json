{
  "name": "Neon Void",
  "description": "Dark futuristic with electric blue & purple glows",
  "author": "Blurski",
  "background": {
    "url": "https://i.imgur.com/8jLAnkH.png",
    "blur": 0,
    "alpha": 0.1
  },
  "theme": {
    "colors": {
      "primary": "#0a0a1a",
